<header>
  <div class="header-wrapper">
    <div class="header-action">
      <!-- Menu Button -->
      <div class="toggle_btn toggle_menu">
        <svg
          stroke="currentColor"
          fill="none"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
          height="1em"
          width="1em"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h7"
          ></path>
        </svg>
      </div>

      <!-- Search Bar -->
      <div class="search">
        <div class="open_search">
          <!-- <button class="btn" type="button" data-bs-toggle="collapse"
                                            href="#multiCollapseSearch" role="button" aria-expanded="false"
                                            aria-controls="multiCollapseSearch">
                                            <i class="fa fa-search"></i>
                                        </button> -->

          <div
            class="collapse multi-collapse Dropdown_search"
            id="multiCollapseSearch"
          >
            <form action="">
              <div class="bg_color">
                <div class="form-group">
                  <input type="text" placeholder="Search..." />
                  <button type="submit"><i class="fa fa-search"></i></button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <div class="header-action-end">
      <!-- Notifications -->
      <div class="notification noty">
        <a
          type="button"
          onclick="loadNotifications()"
          data-bs-toggle="dropdown"
        >
          <i class="fa-regular fa-bell"></i>
          <span class="bell"></span>
        </a>

        <div class="dropdown-menu">
          <div class="card_notify">
            <div class="label">
              <h3 id="notifCount">0 New</h3>
              <p>Leave Application Notifications</p>
            </div>
            <ul id="leaveNotifications" class="notify-list">
              <li class="text-center p-3">Loading...</li>
            </ul>
            <!-- 
                                            <div class="view">
                                                <a href="#">View All Notifications</a>
                                            </div> -->
          </div>
        </div>
      </div>

      <!-- Profile -->
      <div class="profile">
        <a type="button" class="bell-btn" data-bs-toggle="dropdown">
<img id="adminImage" class="pro" src="./images/blog3.jpg">        </a>

        <div class="dropdown-menu">
          <div class="profile_notify">
            <div class="label">
              <div class="img"></div>
              <div>
                <h3 id="adminName">Loading...</h3>
                <span id="adminEmail"></span>
              </div>
            </div>

            <ul>
              <!-- <li><a href="/admin/profile"><i class="bi bi-person"></i>Profile</a></li> -->
              <li>
                <a href="/admin/change-password"
                  ><i class="bi bi-key"></i>Change Password</a
                >
              </li>
              <li>
                <a href="/admin/login"
                  ><i class="bi bi-box-arrow-left"></i>Logout</a
                >
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
<script>
  async function loadNotifications() {
    try {
      const res = await fetch("/admin/pending-leaves");
      const data = await res.json();

      const list = document.getElementById("leaveNotifications");
      const count = document.getElementById("notifCount");

      // ⭐ CLEAR LIST FIRST
      list.innerHTML = "";

      if (!data.success || data.count === 0) {
        list.innerHTML = `<li class="text-center p-3">No Pending Leaves</li>`;
        count.innerText = "0 New";
        return;
      }

      count.innerText = data.count + " New";

      let html = ""; // ⭐ build once

      data.data.forEach((u) => {
        html += `
  <li class="notify-item"
      onclick="window.location='/admin/leave-management/${u.id}'"
      style="cursor:pointer;">
    <div class="notify-name">${u.name}</div>
    <div class="notify-email">${u.email}</div>
  </li>
`;
      });

      list.innerHTML = html; // ⭐ set once
    } catch (err) {
      console.error(err);
    }
  }
 async function loadAdminProfile() {
  try {

    const token = localStorage.getItem("token");
    console.log("Token from localStorage:", token);

    if (!token) {
      console.log("❌ No token found");
      return;
    }

    const res = await fetch("/admin/profile-data", {
      method: "GET",
      headers: {
        "Authorization": "Bearer " + token
      }
    });

    console.log("Response status:", res.status);

    const data = await res.json();
    console.log("API response:", data);
if (data.success) {

  document.getElementById("adminName").textContent = data.data.name;
  document.getElementById("adminEmail").textContent = data.data.email;

  const img = document.getElementById("adminImage");

  if (data.data.profile_image) {
    img.src = "/uploads/" + data.data.profile_image;
  }

}

  } catch (err) {
    console.error("Profile load error:", err);
  }
}


document.addEventListener("DOMContentLoaded", loadAdminProfile);

</script>
<script>
  document.addEventListener("DOMContentLoaded", loadNotifications);

</script>
