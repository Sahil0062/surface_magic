              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
<script>

  // FORMAT DATE SAFELY
  function formatDate(epoch) {

    if (epoch === null || epoch === undefined) return "N/A";

    let timestamp;

    // handle BigInt
    if (typeof epoch === "bigint") {
      timestamp = Number(epoch);
    }
    // handle string numbers
    else if (typeof epoch === "string") {
      timestamp = Number(epoch);
    }
    // handle normal numbers
    else {
      timestamp = epoch;
    }

    if (!timestamp) return "N/A";

    const date = new Date(timestamp);

    if (isNaN(date.getTime())) return "N/A";

    return date.toLocaleDateString("en-IN", {
      day: "numeric",
      month: "short",
      year: "numeric"
    });
  }

  // LOAD LEAVE NOTIFICATIONS
  async function loadNotifications() {
    try {

      const res = await fetch("/admin/pending-leaves");
      const data = await res.json();

      const list = document.getElementById("leaveNotifications");
      const count = document.getElementById("notifCount");
      const bell = document.querySelector(".bell");

      list.innerHTML = "";

      if (!data.success || data.count === 0) {

        list.innerHTML = `<li class="text-center p-3">No Pending Leaves</li>`;
        count.innerText = "0 New";

        if (bell) bell.style.display = "none";

        return;
      }

      count.innerText = data.count + " New";

      if (bell) bell.style.display = "inline-block";

      let html = "";

      data.data.forEach((u) => {

        console.log("start:", u.start_date, "end:", u.end_date);

        const start = formatDate(u.start_date);
        const end = formatDate(u.end_date);

        html += `
        <li class="notify-item"
            onclick="window.location='/admin/leave-management/${u.user_id}'"
            style="cursor:pointer">

            <div class="notify-header">
                <strong>${u.name}</strong>
                <span class="status pending">Pending</span>
            </div>

            <div class="notify-dates">
                📅 ${start} - ${end}
            </div>

            <div class="notify-reason">
                📝 ${u.reason ?? "No reason"}
            </div>

            <div class="notify-email">
                ${u.email}
            </div>

        </li>
        `;
      });

      list.innerHTML = html;

    } catch (err) {
      console.error("Notification load error:", err);
    }
  }


  // LOAD ADMIN PROFILE
  async function loadAdminProfile() {
    try {

      const token = localStorage.getItem("token");

      if (!token) return;

      const res = await fetch("/admin/profile-data", {
        method: "GET",
        headers: {
          "Authorization": "Bearer " + token
        }
      });

      const data = await res.json();

      if (data.success) {

        document.getElementById("adminName").textContent = data.data.name;
        document.getElementById("adminEmail").textContent = data.data.email;

        const img = document.getElementById("adminImage");

        if (data.data.profile_image) {
          img.src = "/uploads/" + data.data.profile_image;
        }

      }

    } catch (err) {
      console.error("Profile load error:", err);
    }
  }


  // PAGE LOAD
  document.addEventListener("DOMContentLoaded", () => {
    loadAdminProfile();
    loadNotifications();
  });

</script>