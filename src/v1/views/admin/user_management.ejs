    <!doctype html>
    <html lang="en">

    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>User Management</title>
        <link rel="icon" type="image/x-icon" href="/assets/images/favicon.png">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
        <link rel="stylesheet" href="/assets/css/custom.css">
    </head>

    <body>

        <div class="main_section">

            <div class="flex_main_sec">

                <!-- sidebar -->
                  <%- include('../partials/sidebar') %>

                <!-- Inner section -->
                <div class="inner_section">
                    <!-- Header -->
                   <%- include('../partials/header') %>

                    <!-- Body Content Here -->
                    <div class="body_content">

                        <div class="block_section common_heading">
                            <div class="cont">
                                <h2>User Management</h2>
                                <h3>Manage employee credentials and monitor attendance</h3>
                            </div>
                            <div class="button">
                                <a class="btn" data-bs-toggle="modal" data-bs-target="#staticBackdrop"><i
                                        class="bi bi-plus-lg"></i>Add Employee</a>
                            </div>

                        </div>

                        <!-- Common Search bar -->
                        <div class="common_search">
    <div class="form-group">
        <form method="GET" action="/admin/user-management" class="form-group d-flex">

            <input type="text"
                   name="search"
                   value="<%= search || '' %>"
                   class="form-control"
                   placeholder="Search users...">

            <button type="submit">
                <i class="bi bi-search"></i>
            </button>

        </form>
    </div>
</div>

                        <!-- Table Section Ends Here -->
                        <div class="recent_order Management_table">

                            <!-- <h2>Recent Activity</h2> -->

                            <div class="table-responsive">
                                <table class="table user-table">
                                    <thead>
                                        <tr>
                                            <th scope="col">Image</th>
                                            <th scope="col">Name</th>
                                            <th scope="col">Email</th>
                                            <th scope="col">Enable / Disable</th>
                                            <th scope="col">Actions</th>

                                        </tr>
                                    </thead>
                                    <tbody>
    <% if (users && users.length > 0) { %>
    <% users.forEach(user => { %>
        <tr>
        <td>
            <div class="id">
            <!-- <img src="<%= user.profile_image || '/assets/images/default-user.png' %>" width="40"> -->
            <% if (user.profile_image) { %>
        <img src="<%= user.profile_image %>" width="40" class="rounded-circle">
    <% } else { %>
        <div class="avatar-circle">
            <%= user.name ? user.name.charAt(0).toUpperCase() : "U" %>
        </div>
    <% } %>

            </div>
        </td>

        <td>
            <div class="mail"><%= user.name %></div>
        </td>

        <td><%= user.email %></td>

        <td>
            <div class="enable_btn">
                <div class="form-check form-switch">
    <input class="form-check-input toggle-status"
            type="checkbox"
            data-id="<%= user.id %>"
            <%= user.status === "active" ? "checked" : "" %>>
    </div>
            <a href="/admin/leave-management/<%= user.id %>" class="btn">Leave</a>
            </div>
        </td>

        <td>
            <div class="action_btn">
<a href="/admin/job-assignment?employee=<%= user.id %>" class="detele">
<i class="bi bi-eye"></i>
</a>            <a href="#" class="delete-user detele red" data-id="<%= user.id %>"> <i class="bi bi-trash3"></i></a>
                <a class="detele green edit-btn"
    data-id="<%= user.id %>"
    data-name="<%= user.name %>"
    data-email="<%= user.email %>"
    data-image="<%= user.profile_image || '' %>"
    data-bs-toggle="modal"
    data-bs-target="#editEmployeeModal">

    <i class="bi bi-pencil-square"></i>
    </a> 
            <!-- <a href="/admin/user/delete/<%= user.id %>" class="detele red"><i class="bi bi-trash3"></i></a> -->
            </div>
        </td>
        </tr>
    <% }) %>
    <% } else { %>
    <tr>
        <td colspan="5" class="text-center">No users found</td>
    </tr>
    <% } %>
    </tbody>


                                </table>
                            </div>

                        </div>

                        <!-- Pagination -->
            <%- include('../partials/pagination', {
    currentPage,
    totalPages,
    baseUrl: `/admin/user-management`,
    search
}) %>
                    </div>

                    <!-- Footer -->

                    <footer>
                        <div class="flex_box">
                            <h3>Copyright © 2026 <span>Surface Magic</span> All rights reserved.</h3>
                        </div>
                    </footer>

                </div>

            </div>
        </div>

        <!-- Add Employee Modal -->
        <div class="modal fade Employee_popup" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false"
            tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 class="modal-title fs-5" id="staticBackdropLabel">Add New Employee</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form id="addEmployeeForm" enctype="multipart/form-data">

    <div class="modal-body">

        <div class="avatar-upload">
            <div class="avatar-edit">
                <input type="file"
                    id="imageUpload"
                    name="profile_image"
                    accept=".png,.jpg,.jpeg" />
                <label for="imageUpload"></label>
            </div>

            <div class="avatar-preview">
                <div id="imagePreview"
                    style="background-image:url('/assets/images/default-user.png');">
                </div>
            </div>
        </div>

        <div class="form-group">
            <label>Full Name</label>
            <input type="text" name="name" class="form-control" required>
        </div>

        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" class="form-control" required>
        </div>

        <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" class="form-control" required>
        </div>

    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Add Employee</button>
    </div>

    </form>
                    
                </div>
            </div>
        </div>
        <div class="modal fade Employee_popup" id="editEmployeeModal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

        <div class="modal-header">
            <h2>Edit Employee</h2>
            <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <form id="editEmployeeForm" enctype="multipart/form-data">
            <!-- <input type="hidden" name="id" id="editUserId"> -->
             <input type="hidden" id="editUserId">

            <div class="modal-body">

            <div class="avatar-upload">
                <div class="avatar-edit">
                <input type="file" name="profile_image" id="editImageUpload">
                <label for="editImageUpload"></label>
                </div>

                <div class="avatar-preview">
                <div id="editImagePreview"
                    style="background-image:url('/assets/images/default-user.png');">
                </div>
                </div>
            </div>

            <div class="form-group">
                <label>Full Name</label>
                <input type="text" name="name" id="editName" class="form-control">
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" id="editEmail" class="form-control">
            </div>

            </div>

            <div class="modal-footer">
            <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Update Employee</button>
            </div>

        </form>

        </div>
    </div>
    </div>



        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
        <script src="/assets/js/custom.js"></script>
        <script>
    document.getElementById("addEmployeeForm")
    .addEventListener("submit", async function(e) {
        e.preventDefault();

        const formData = new FormData(this);

        try {
            const res = await fetch("/admin/add-employee", {
                method: "POST",
                body: formData
            });

            const data = await res.json();
            // alert(data.message);

            if (res.ok) location.reload();

        } catch (err) {
            console.error(err);
            // alert("Error adding employee");
            console.error("Error adding employee");
        }
    });
    </script>
    <script>
    document.getElementById("imageUpload").onchange = function () {
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById("imagePreview")
                .style.backgroundImage = `url(${e.target.result})`;
        };
        reader.readAsDataURL(this.files[0]);
    };
    </script>


    <script>
    document.querySelectorAll(".toggle-status").forEach(toggle => {
    toggle.addEventListener("change", async function () {

        const userId = this.dataset.id;
        const status = this.checked ? "active" : "inactive";

        console.log("Sending:", userId, status);

        try {
        const res = await fetch(`/admin/user-status/${userId}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ status })
        });

        const text = await res.text();
        console.log("Server response:", text);

        } catch (err) {
        console.error(err);
        alert("Error updating status");
        }
    });
    });
    </script>
    <script>
    document.querySelectorAll(".edit-btn").forEach(btn => {

    btn.addEventListener("click", function(){

        document.getElementById("editUserId").value = this.dataset.id;
        document.getElementById("editName").value = this.dataset.name;
        document.getElementById("editEmail").value = this.dataset.email;

        if(this.dataset.image){
        document.getElementById("editImagePreview")
            .style.backgroundImage = `url(${this.dataset.image})`;
        }

    });

    });
    </script>
    <script>
   document.getElementById("editEmployeeForm")
.addEventListener("submit", async function(e){

    e.preventDefault();

    const formData = new FormData(this);

    const id = document.getElementById("editUserId").value;

    try {

        const res = await fetch(`/admin/user/edit/${id}`, {
            method: "PUT",
            body: formData
        });

        const data = await res.json();

        // alert(data.message);

        if(res.ok) location.reload();

    } catch(err){

        console.error(err);
        // alert("Update failed");
        console.error("Update failed");

    }

});
    </script>
    <script>
    document.querySelectorAll(".delete-user").forEach(btn => {
    btn.addEventListener("click", async function(e) {
        e.preventDefault();

        // if (!confirm("Delete this employee?")) return;

        const userId = this.dataset.id;

        try {
        const res = await fetch(`/admin/user/delete/${userId}`, {
            method: "POST"
        });

        const data = await res.json();

        if (res.ok) {
            // alert(data.message);

            // ✅ REMOVE ROW FROM TABLE
            this.closest("tr").remove();

        } else {
            // alert("Delete failed");
            console.error("Delete failed");
        }

        } catch (err) {
        console.error(err);
        alert("Delete failed");
        }
    });
    });
    </script>
    </body>

    </html>