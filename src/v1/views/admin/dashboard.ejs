<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Dashboard</title>
    <link rel="icon" type="image/x-icon" href="/assets/images/favicon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
    <link rel="stylesheet" href="/assets/css/custom.css">



</head>

<body>

    <div class="main_section">

        <div class="flex_main_sec">

            <!-- sidebar -->
            <%- include("../partials/sidebar", { active: "dashboard" }) %>

                <!-- Inner section -->
                <div class="inner_section">
                    <!-- Header -->
                    <%- include("../partials/header") %>

                        <!-- Body Content Here -->
                        <div class="body_content">

                            <div class="block_section">
                                <h2>Dashboard Overview</h2>
                                <h3>Real-time metrics and recent activity</h3>

                                <div class="grid_box">

                                    <!-- Active Jobs -->
                                    <div class="set" onclick="window.location='/admin/job-assignment?status=assigned'"
                                        style="cursor:pointer;">
                                        <h4>Active Jobs</h4>
                                        <div class="cont">
                                            <h5>
                                                <%= activeJobs %>
                                            </h5>
                                            <div class="icon">
                                                <i class="bi bi-activity"></i>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Pending Approval -->
                                    <div class="set" onclick="window.location='/admin/leave-management?status=pending'"
                                        style="cursor:pointer;">
                                        <h4>Pending Approval</h4>
                                        <div class="cont">
                                            <h5>
                                                <%= pendingLeaves %>
                                            </h5>
                                            <div class="icon">
                                                <i class="bi bi-exclamation-circle"></i>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Completed Today -->
                                    <div class="set" onclick="window.location='/admin/job-assignment?status=completed'"
                                        style="cursor:pointer;">
                                        <h4>Completed Today</h4>
                                        <div class="cont">
                                            <h5>
                                                <%= completedToday %>
                                            </h5>
                                            <div class="icon">
                                                <i class="bi bi-check2-circle"></i>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Employees Clocked In -->
                                    <div class="set" onclick="window.location='/admin/job-assignment'"
                                        style="cursor:pointer;">
                                        <h4>Employees Clocked In</h4>
                                        <div class="cont">
                                            <h5>
                                                <%= clockedIn %>
                                            </h5>
                                            <div class="icon">
                                                <i class="bi bi-clock"></i>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>

                            <!-- Table Section Ends Here -->

                            <div class="recent_order">

                                <h2>Recent Activity</h2>

                                <div class="table-responsive">
                                    <table class="table">
                                        <thead>
                                            <tr>
                                                <th scope="col">Employee</th>
                                                <th scope="col">Status</th>
                                                <th scope="col">Date / Time</th>
                                                <th scope="col">Client</th>
                                            </tr>
                                        </thead>
                                        <tbody>

                                            <% if(!recentJobs || recentJobs.length===0){ %>
                                                <tr>
                                                    <td colspan="4" class="text-center">No jobs scheduled for today</td>
                                                </tr>
                                                <% } %>

                                                    <% recentJobs.forEach(job=> { %>
                                                        <tr>

                                                            <!-- EMPLOYEE -->
                                                            <td>
                                                                <div
                                                                    style="display:flex; align-items:center; gap:12px;">

                                                                    <!-- Profile Image -->
                                                                    <img src="<%= job.emp_image 
                ? '/uploads/' + job.emp_image 
                : '/assets/images/profile.avif' %>" style="width:50px; height:50px; border-radius:50%; object-fit:cover;">

                                                                    <!-- Name + Email -->
                                                                    <div style="display:flex; flex-direction:column;">
                                                                        <strong style="font-size:16px;">
                                                                            <%= job.emp_name || 'Not Assigned' %>
                                                                        </strong>
                                                                        <span style="font-size:14px; color:#6c757d;">
                                                                            <%= job.emp_email || '' %>
                                                                        </span>
                                                                    </div>

                                                                </div>
                                                            </td>

                                                            <!-- STATUS -->
                                                            <td>
                                                                <div class="pending 
        <%= job.display_status === 'failed' ? 'red' : '' %>
        <%= job.display_status === 'assigned' ? 'green' : '' %>
        <%= job.display_status === 'in_progress' ? 'blue' : '' %>
        <%= job.display_status === 'completed' ? 'green' : '' %>">

                                                                    <span></span>

                                                                    <%= job.display_status.replace('_',' ') %>

    </div>
    </td>

    <!-- DATE & TIME -->
    <td>
        <%= new Date(Number(job.job_date)).toLocaleDateString() %>
        <span class="time">
        <%= job.start_time 
? new Date(Number(job.start_time)).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) 
: '-' %>
                                                                        -
                                                                        <%= job.end_time ? new
                                                                            Date(Number(job.end_time)).toLocaleTimeString([],
                                                                            {hour:'2-digit', minute:'2-digit'}) : '-' %>
                                                                            </span>
                                                            </td>

                                                            <!-- CLIENT -->
                                                            <td>
                                                                <div class="mail">
                                                                    <div>
                                                                        <strong
                                                                            style="font-size:16px;color:#6c757d;font-weight: 700;">
                                                                            <%= job.client_name || '-' %>
                                                                        </strong>
                                                                        <span>
                                                                            <%= job.client_email || '' %>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            </td>

                                                        </tr>
                                                        <% }) %>

                                        </tbody>
                                    </table>
                                </div>

                            </div>

                        </div>

                        <!-- Footer -->

                        <%- include('../partials/footer') %>

                </div>

        </div>
    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="/assets/js/custom.js"></script>
</body>

</html>