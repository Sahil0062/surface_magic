<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Leave Management</title>
    <link rel="icon" type="image/x-icon" href="/assets/images/favicon.png" />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
    />
    <link rel="stylesheet" href="/assets/css/custom.css" />
  </head>

  <body>

    <% if(success){ %>
<script>
  alert("<%= success %>");
</script>
<% } %>
    <div class="main_section">
      <div class="flex_main_sec">
        <!-- sidebar -->
          <%- include('../partials/sidebar') %>


        <!-- Inner section -->
        <div class="inner_section">
          <!-- Header -->
           <%- include('../partials/header') %>


          <!-- Body Content Here -->
          <div class="body_content">
            <div class="block_section">
              <div class="common_heading">
                <div class="cont">
                  <h2>Leave Management</h2>
                  <h3>Request and manage your leave applications</h3>
                </div>
                <% if(selectedUser){ %>
  <!-- <a href="/admin/leave-management" class="btn btn-secondary mb-2">
    ← Back to All Leaves
  </a> -->
<% } %>
                <div class="button">
                  <a
                    class="btn"
                    data-bs-toggle="modal"
                    data-bs-target="#leaveRequest"
                    ><i class="bi bi-plus-lg"></i>Request Leave</a
                  >
                </div>
              </div>

              <div class="grid_box">
                <div class="set">
                  <h4>Total Requests</h4>
                  <div class="cont">
                    <h5><%= stats?.total || 0 %></h5>
                    <div class="icon">
                      <i class="bi bi-calendar-check"></i>
                    </div>
                  </div>
                </div>

                <div class="set">
                  <h4>Pending</h4>
                  <div class="cont">
                    <h5><%= stats?.pending || 0 %></h5>

                    <div class="icon">
                      <i class="bi bi-clock"></i>
                    </div>
                  </div>
                </div>

                <div class="set">
                  <h4>Approved</h4>
                  <div class="cont">
                    <h5><%= stats?.approved || 0 %></h5>
                    <div class="icon">
                      <i class="bi bi-check2-circle"></i>
                    </div>
                  </div>
                </div>

                

                <div class="set">
                  <h4>Rejected</h4>
                  <div class="cont">
                    <h5><%= stats?.rejected || 0 %></h5>
                    <div class="icon">
                      <i class="bi bi-x-circle"></i>
                    </div>
                  </div>
                </div>

                
              </div>
            </div>


            <!-- Common Search bar -->
            <div class="common_search">
              <div class="form-group">
                <input
                  type="text"
                  class="form-control"
                  placeholder="Search..."
                />
                <button type="submit"><i class="bi bi-search"></i></button>
              </div>
            </div>

            <!-- Table Section Ends Here -->
            <div class="recent_order job_table">
              <!-- <h2>Recent Activity</h2> -->

              <div class="table-responsive">
                <table class="table leave-table">
                  <thead>
                    <tr>
                      <th scope="col">Employee</th>
                      <th scope="col">Date</th>
                      <th scope="col">Days</th>
                      <th scope="col">Reason</th>
                      <th scope="col">Status</th>
                      <th scope="col">Action</th>
                    </tr>
                  </thead>
                  <tbody>

<% if(leaves.length === 0){ %>
<tr>
<td colspan="6" class="text-center">No leave requests</td>
</tr>
<% } %>

<% leaves.forEach(l => { %>

<tr>
<td>
    <div class="mail">
        <%= l.employee_name %>
        <span><%= l.employee_email %></span>
    </div>
</td>
<td class="date_break">
    <%= l.start_date || '-' %>
    <span><%= l.end_date || '-' %></span>
</td>

<td><%= l.total_days %> Days</td>

<td>
  <%= l.reason %>

  <% if(l.applied_by_admin){ %>
    <span class="badge bg-warning ms-2">Emergency</span>
  <% } %>
</td>

<td>
    <div class="pending 
        <%= l.status==='pending'?'yellow':'' %>
        <%= l.status==='rejected'?'red':'' %>">
        <span></span>
        <%= l.status.charAt(0).toUpperCase()+l.status.slice(1) %>
    </div>
</td>

<td>
<% if(l.status === 'pending'){ %>
    <div class="accept">
        <form action="/admin/leave/<%= l.id %>/approve" method="POST" style="display:inline;">
            <button class="btn">Accept</button>
        </form>

        <form action="/admin/leave/<%= l.id %>/reject" method="POST" style="display:inline;">
            <button class="btn reject">Reject</button>
        </form>
    </div>

    <% } else { %>
        <span>-</span>
    <% } %>
</td>

</tr>

<% }) %>

</tbody>
                </table>
              </div>
            </div>

            <!-- Pagination -->
   <%- include('../partials/pagination', {
    currentPage: currentPage,
    totalPages: totalPages,
    baseUrl: '/admin/leave-management'
}) %>
          </div>

          <!-- Footer -->
<%- include('../partials/footer') %>
        </div>
      </div>
    </div>

    <!-- New Leave Request Modal -->
    <div
      class="modal fade Employee_popup"
      id="leaveRequest"
      data-bs-backdrop="static"
      data-bs-keyboard="false"
      tabindex="-1"
      aria-labelledby="staticBackdropLabel"
      aria-hidden="true"
    >
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h2 class="modal-title fs-5" id="staticBackdropLabel">
              New Leave Request
            </h2>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
              aria-label="Close"
            ></button>
          </div>
          <div class="modal-body">

<form id="applyLeaveForm">
  <div class="form-group">
    <label>Select Employee</label>
    <select class="form-select" name="user_id" required>
      <option disabled selected>Select Employee</option>
      <% employees.forEach(emp => { %>
        <option value="<%= emp.id %>">
          <%= emp.name %> - <%= emp.email %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="grid_box">
    <div class="form-group">
      <label>Start Date</label>
      <input type="date" name="start_date" class="form-control" required />
    </div>

    <div class="form-group">
      <label>End Date</label>
      <input type="date" name="end_date" class="form-control" required />
    </div>
  </div>

  <div class="form-group">
    <label>Reason</label>
    <textarea name="reason" class="form-control"></textarea>
  </div>

  <div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
      Cancel
    </button>
    <button type="submit" class="btn btn-primary">
      Submit Request
    </button>
  </div>

</form>

</div>

        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="/assets/js/custom.js"></script>
    <script>
document.getElementById("applyLeaveForm")
.addEventListener("submit", async function(e){

  e.preventDefault();

  const body = {
    user_id: document.querySelector("[name=user_id]").value,
    start_date: document.querySelector("[name=start_date]").value,
    end_date: document.querySelector("[name=end_date]").value,
    reason: document.querySelector("[name=reason]").value
  };

  try {

    const res = await fetch("/admin/apply-leave", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body)
    });

    const data = await res.json();

    alert(data.message);   // ✅ SAME LIKE CLIENT PAGE

    if(res.ok){
      location.reload();
    }

  } catch(err){
    alert("Leave request failed");
  }
});
</script> 
  </body>
</html>
