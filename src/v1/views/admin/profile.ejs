 <!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Profile</title>
    <link rel="icon" type="image/x-icon" href="/assets/images/favicon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
    <link rel="stylesheet" href="/assets/css/custom.css">
</head>

<body>

    <div class="main_section">

        <div class="flex_main_sec">

            <!-- sidebar -->
                           <%- include('../partials/sidebar') %>

            <!-- Inner section -->
            <div class="inner_section">
                <!-- Header -->
                <%- include('../partials/header') %>


                <!-- Body Content Here -->
                <div class="body_content">


                    <!-- Profile Section -->
                    <div class="profile_sec">
                        <div class="box">
                            <h2>Update Admin Profile</h2>

                            <div class="avatar-upload">
                                <div class="avatar-edit">
                                    <input type='file' id="imageUpload" accept=".png, .jpg, .jpeg" />
                                    <label for="imageUpload"></label>
                                </div>
                                <div class="avatar-preview">
                                    <div id="imagePreview" style="background-image: url(./images/profile.avif);">
                                    </div>

                                </div>
                                <h3>Upload Image</h3>

                            </div>

                            <form>
                                <div class="form_profile">
                                    <div class="grid_box">
                                        <div class="form-group">
                                            <label>Name</label>
                                            <input type="text" class="form-control" placeholder="Riya Sharma">
                                        </div>

                                        <div class="form-group">
                                            <label>Email Address</label>
                                            <input type="email" class="form-control" placeholder="admin@gmail.com">
                                        </div>

                                       

                                    </div>
                                    <div class="button">
                                        <button type="submit">Submit</button>
                                    </div>
                                </div>
                            </form>

                        </div>
                    </div>



                </div>

                <!-- Footer -->

                <footer>
                    <div class="flex_box">
                        <h3>Copyright © 2026 <span>Surface Magic</span> All rights reserved.</h3>
                    </div>
                </footer>

            </div>

        </div>
    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="/assets/js/custom.js"></script>
</body>

</html> 