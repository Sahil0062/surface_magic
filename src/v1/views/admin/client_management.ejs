<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Client Management</title>
    <link rel="icon" type="image/x-icon" href="/assets/images/favicon.png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
    <link rel="stylesheet" href="/assets/css/custom.css">
</head>

<body>

    <div class="main_section">

        <div class="flex_main_sec">

            <!-- sidebar -->
            <%- include('../partials/sidebar') %>

                <!-- Inner section -->
                <div class="inner_section">
                    <!-- Header -->
                    <%- include('../partials/header') %>

                        <!-- Body Content Here -->
                        <div class="body_content">

                            <div class="block_section common_heading">
                                <div class="cont">
                                    <h2>Client Management</h2>
                                    <h3>Manage client records and job details</h3>
                                </div>
                                <div class="button">
                                    <a class="btn" data-bs-toggle="modal" data-bs-target="#staticBackdrop"><i
                                            class="bi bi-plus-lg"></i>Add Client</a>
                                </div>

                            </div>

                            <!-- Common Search bar -->
                            <div class="common_search">
                                <div class="form-group">
                                    <form method="GET" action="/admin/client" class="form-group d-flex">

                                        <input type="text" id="clientSearch" name="search" value="<%= search || '' %>"
                                            class="form-control" placeholder="Search clients...">

                                        <button type="submit">
                                            <i class="bi bi-search"></i>
                                        </button>

                                    </form>
                                </div>

                            </div>

                            <!-- Table Section Ends Here -->
                            <div class="recent_order Management_table">

                                <!-- <h2>Recent Activity</h2> -->

                                <div class="table-responsive">
                                    <table class="table client-table">
                                        <thead>
                                            <tr>
                                                <th scope="col">Name</th>
                                                <th scope="col">Email</th>
                                                <th scope="col">Phone No</th>
                                                <th scope="col">Action</th>

                                            </tr>
                                        </thead>
                                        <tbody id="clientTableBody">
                                            <% if (clients && clients.length> 0) { %>
                                                <% clients.forEach(client=> { %>

                                                    <tr>
                                                        <td>
                                                            <div class="mail">
                                                                <%= client.name %>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <%= client.email %>
                                                        </td>
                                                        <td>
                                                            <%= client.phone || "-" %>
                                                        </td>

                                                        <td>
                                                            <div class="action_btn">
                                                                <a class="detele green">
                                                                    <i class="bi bi-download"></i></a>
                                                                <!-- <a href="/admin/client/edit/<%= client.id %>" class="detele green">
                <i class="bi bi-pencil-square"></i>
            </a> --><a class="detele green edit-client-btn" data-id="<%= client.id %>" data-name="<%= client.name %>"
                                                                    data-email="<%= client.email %>"
                                                                    data-phone="<%= client.phone %>"
                                                                    data-bs-toggle="modal"
                                                                    data-bs-target="#editClientModal">

                                                                    <i class="bi bi-pencil-square"></i>
                                                                </a>

                                                                <a href="#" class="delete-client detele red"
                                                                    data-id="<%= client.id %>">
                                                                    <i class="bi bi-trash3"></i>
                                                                </a>    
                                                            </div>
                                                        </td>
                                                    </tr>

                                                    <% }) %>

                                                        <% } else { %>
                                                            <tr>
                                                                <td colspan="4" class="text-center">No clients found
                                                                </td>
                                                            </tr>
                                                            <% } %>

                                        </tbody>


                                    </table>
                                </div>

                            </div>

                            <!-- Pagination -->
                            <%- include('../partials/pagination', { currentPage, totalPages, baseUrl: `/admin/client`,
                                search, status }) %>
                        </div>
                                        
                        <!-- Footer -->

                        <%- include('../partials/footer') %>

                </div>

        </div>
    </div>

    <!-- Add client Modal -->
    <div class="modal fade Employee_popup" id="staticBackdrop">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h2>Add New Client</h2>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- ✅ FORM START -->
                <form id="addClientForm">

                    <div class="modal-body">

                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" id="clientName" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" id="clientEmail" class="form-control" required>
                        </div>

                        <div class="form-group">
                            <label>Phone No</label>
                            <input type="tel" id="clientPhone" class="form-control" required>
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>

                        <button type="submit" class="btn btn-primary">
                            Add Client
                        </button>
                    </div>

                </form>
                <!-- ✅ FORM END -->

            </div>
        </div>
    </div>

    <div class="modal fade Employee_popup" id="editClientModal">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h2>Edit Client</h2>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <form id="editClientForm">
                    <input type="hidden" id="editClientId">

                    <div class="modal-body">

                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" id="editClientName" class="form-control">
                        </div>

                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" id="editClientEmail" class="form-control">
                        </div>

                        <div class="form-group">
                            <label>Phone No</label>
                            <input type="tel" id="editClientPhone" class="form-control">
                        </div>

                    </div>

                    <div class="modal-footer">
                        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Update Client</button>
                    </div>

                </form>

            </div>
        </div>
    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="/assets/js/custom.js"></script>

    <script>
        document.querySelectorAll(".edit-client-btn").forEach(btn => {

            btn.addEventListener("click", function () {

                document.getElementById("editClientId").value = this.dataset.id;
                document.getElementById("editClientName").value = this.dataset.name;
                document.getElementById("editClientEmail").value = this.dataset.email;
                document.getElementById("editClientPhone").value = this.dataset.phone;

            });

        });
    </script>
    <script>
        document.getElementById("editClientForm")
            .addEventListener("submit", async function (e) {

                e.preventDefault();

                const id = document.getElementById("editClientId").value;

                const body = {
                    name: document.getElementById("editClientName").value,
                    email: document.getElementById("editClientEmail").value,
                    phone: document.getElementById("editClientPhone").value,
                };

                try {
                    const res = await fetch(`/admin/client/edit/${id}`, {
                        method: "PUT",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(body)
                    });

                    const data = await res.json();
                    // alert(data.message);

                    if (res.ok) location.reload();

                } catch (err) {
                    alert("Update failed");
                }

            });
    </script>
    <script>
        document.addEventListener("click", async function (e) {

            const btn = e.target.closest(".delete-client");
            if (!btn) return;

            e.preventDefault();

            if (!confirm("Delete this client?")) return;

            const id = btn.dataset.id;

            try {
                const res = await fetch(`/admin/client/delete/${id}`, {
                    method: "DELETE"
                });

                const data = await res.json();

                if (res.ok) {
                    // alert(data.message);
                    btn.closest("tr").remove();
                } else {
                    alert("Delete failed");
                }

            } catch (err) {
                console.error(err);
                alert("Delete failed");
            }

        });
    </script>
    <script>
        document.getElementById("addClientForm")
            .addEventListener("submit", async function (e) {

                e.preventDefault();

                const body = {
                    name: document.getElementById("clientName").value,
                    email: document.getElementById("clientEmail").value,
                    phone: document.getElementById("clientPhone").value
                };

                try {

                    const res = await fetch("/admin/add-client", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(body)
                    });

                    const data = await res.json();

                    if (!res.ok) {
                        alert(data.message); // show alert only for error
                        return;
                    }

                    location.reload(); // success → reload silently

                } catch (err) {
                    console.error(err);
                    alert("Add client failed");
                }

            });
    </script>
    <script>
        const searchInput = document.getElementById("clientSearch");

        searchInput.addEventListener("input", function () {

            const search = this.value;

            fetch(`/admin/client?search=${encodeURIComponent(search)}`, {
                headers: {
                    "X-Requested-With": "XMLHttpRequest"
                }
            })
                .then(res => res.text())
                .then(html => {

                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, "text/html");

                    const newRows = doc.querySelector("#clientTableBody").innerHTML;

                    document.getElementById("clientTableBody").innerHTML = newRows;

                })
                .catch(err => console.error("Search error:", err));

        });
    </script>
</body>

</html>