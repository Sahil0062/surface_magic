<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Job Detail View</title>

  <link rel="icon" type="image/x-icon" href="/assets/images/favicon.png">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />

  <link rel="stylesheet" href="/assets/css/custom.css">
  <style>
    .photo-box img {
      height: 350px;
      object-fit: cover;
      border-radius: 10px;
    }
  </style>
</head>

<body>

  <div class="main_section">

    <div class="flex_main_sec">

      <!-- Sidebar -->
      <%- include('../partials/sidebar') %>


        <!-- Inner Section -->
        <div class="inner_section">

          <!-- Header -->
          <%- include('../partials/header') %>


            <!-- Body Content -->
            <div class="body_content">


              <div class="view_job_sec">

                <!-- JOB HEADER -->

                <div class="header">

                  <h3>
                    <%= job.job_date %>,
                      <%= job.start_time %> - <%= job.end_time %>
                  </h3>

                  <span>
                    <%= job.client_name %>
                  </span>
                </div>



                <div class="grid">


                  <!-- LEFT SIDE -->
                  <div class="left">


                    <!-- Job Detail -->

                    <div class="box">

                      <h4>Job Detail</h4>

                      <div class="card">

                        <strong>
                          <%= job.title %>
                        </strong>

                        <p>
                          <%= job.description %>
                        </p>

                      </div>

                    </div>



                    <!-- Contact -->

                    <div class="box">
                      <h4>Contact</h4>

                      <div class="card">
                        <%= job.client_phone ? job.client_phone : 'N/A' %>
                      </div>
                    </div>


                    <!-- Email -->

                    <div class="box">
                      <h4>Email</h4>

                      <div class="card">
                        <%= job.client_email ? job.client_email : 'N/A' %>
                      </div>
                    </div>


                    <!-- Location -->

                    <div class="box">

                      <h4>Location</h4>

                      <div class="card">

                        <%= job.address ? job.address : 'No Address Provided' %>

                      </div>

                    </div>



                    <!-- Note -->

                    <div class="box">

                      <h4>Note</h4>

                      <div class="card">

                        <%= job.note ? job.note : 'No Note Added' %>

                      </div>

                    </div>


                  </div>



                  <!-- RIGHT SIDE -->
                  <div class="right">


                    <!-- Uploaded Photo -->

                    <div class="box">

                      <h4>Uploaded Photo</h4>

                      <div class="card photo-box">

                        <% let photos=[]; if (job.upload_photo) { try { photos=JSON.parse(job.upload_photo); } catch (e)
                          { photos=[job.upload_photo]; } } %>

                          <% if(photos.length> 0){ %>

                            <% if(photos.length> 0){ %>

                              <div id="jobPhotoCarousel" class="carousel slide" data-bs-ride="carousel">

                                <div class="carousel-inner">

                                  <% photos.forEach((photo, index)=> { %>
                                    <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                                      <img src="/uploads/<%= photo %>" class="d-block w-100 rounded">
                                    </div>
                                    <% }) %>

                                </div>

                                <!-- Left Arrow -->
                                <button class="carousel-control-prev" type="button" data-bs-target="#jobPhotoCarousel"
                                  data-bs-slide="prev">
                                  <span class="carousel-control-prev-icon"></span>
                                </button>

                                <!-- Right Arrow -->
                                <button class="carousel-control-next" type="button" data-bs-target="#jobPhotoCarousel"
                                  data-bs-slide="next">
                                  <span class="carousel-control-next-icon"></span>
                                </button>

                              </div>

                              <% } else { %>

                                <p>No Photo Uploaded</p>

                                <% } %>

                                  <% } else { %>

                                    <p>No Photo Uploaded</p>

                                    <% } %>

                      </div>

                    </div>



                    <!-- Client Signature -->

                    <div class="box signature">

                      <h4>Client Signature</h4>

                      <div class="card">

                        <% if(job.client_signature){ %>

                          <img src="/uploads/<%= job.client_signature %>" class="img-fluid">

                          <% } else { %>

                            <p>No Signature</p>

                            <% } %>

                      </div>

                    </div>


                  </div>

                </div>


              </div>


            </div>


            <!-- Footer -->

            <footer>

              <div class="flex_box">

                <h3>Copyright © 2026 <span>Surface Magic</span> All rights reserved.</h3>

              </div>

            </footer>


        </div>


    </div>


  </div>



  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>

  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

  <script src="/assets/js/custom.js"></script>

</body>

</html>